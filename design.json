  "typography": {
    "fontFamilies": {
      "primary": {
        "name": "Plus Jakarta Sans",
        "fallback": "'Plus Jakarta Sans', 'Inter', system-ui, -apple-system, sans-serif",
        "source": "https://fonts.google.com/specimen/Plus+Jakarta+Sans",
        "weights": [400, 500, 600, 700, 800],
        "usage": "Body text, dashboard UI, all non-heading text"
      },
      "display": {
        "name": "Syne",
        "fallback": "'Syne', system-ui, sans-serif",
        "source": "https://fonts.google.com/specimen/Syne",
        "weights": [500, 600, 700, 800],
        "usage": "Landing page headings, hero headline, section titles, logo text, stats numbers"
      },
      "mono": {
        "name": "DM Mono",
        "fallback": "'DM Mono', 'Fira Code', 'Courier New', monospace",
        "source": "https://fonts.google.com/specimen/DM+Mono",
        "weights": [400, 500]
      }
    },
    "scale": {
      "display-xl": {
        "fontSize": "72px",
        "fontSizeRem": "4.5rem",
        "fontWeight": 800,
        "lineHeight": 1.0,
        "letterSpacing": "-2px",
        "fontFamily": "primary",
        "usage": "Landing hero heading"
      },
      "display-lg": {
        "fontSize": "48px",
        "fontSizeRem": "3rem",
        "fontWeight": 700,
        "lineHeight": 1.1,
        "letterSpacing": "-1.5px",
        "fontFamily": "primary",
