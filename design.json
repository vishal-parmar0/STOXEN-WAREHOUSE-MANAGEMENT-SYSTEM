      },
      "body-md": {
        "fontSize": "14px",
        "fontSizeRem": "0.875rem",
        "fontWeight": 400,
        "lineHeight": 1.5,
        "letterSpacing": "0",
        "fontFamily": "primary",
        "usage": "Default UI text, table cells"
      },
      "body-sm": {
        "fontSize": "12px",
        "fontSizeRem": "0.75rem",
        "fontWeight": 400,
        "lineHeight": 1.4,
        "letterSpacing": "0.2px",
        "fontFamily": "primary",
        "usage": "Labels, badges, captions"
      },
      "body-xs": {
        "fontSize": "11px",
        "fontSizeRem": "0.6875rem",
        "fontWeight": 500,
        "lineHeight": 1.3,
        "letterSpacing": "0.3px",
        "fontFamily": "primary",
        "usage": "Overline text, eyebrow labels"
      },
      "mono-lg": {
        "fontSize": "20px",
        "fontSizeRem": "1.25rem",
        "fontWeight": 500,
        "lineHeight": 1.2,
        "letterSpacing": "0",
        "fontFamily": "mono",
        "usage": "Large quantities, prices"
      },
      "mono-md": {
        "fontSize": "14px",
        "fontSizeRem": "0.875rem",
        "fontWeight": 400,
        "lineHeight": 1.4,
        "letterSpacing": "0",
        "fontFamily": "mono",
        "usage": "SKU codes, small numbers"
      }
