  "breakpoints": {
    "xs": "0px",
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px",
    "responsiveRules": {
      "xl": "Full 3-column layout (sidebar + main + right panel)",
      "lg": "Right panel hidden, main takes full width with sidebar",
      "md": "Sidebar collapses to 64px icon-only mode",
      "sm": "Sidebar becomes slide-out drawer, single column content",
      "xs": "Full mobile — stacked cards, hamburger menu"
    }
  },

  "animations": {
    "pageTransition": {
      "type": "fade-in + slide-up",
      "offset": "8px",
      "duration": "200ms",
      "easing": "ease-out"
    },
    "modalOpen": {
      "type": "fade-in + scale",
      "scaleFrom": 0.95,
      "duration": "150ms",
      "easing": "ease-out"
    },
    "modalClose": {
      "type": "fade-out + scale",
      "scaleTo": 0.95,
      "duration": "100ms",
      "easing": "ease-in"
    },
    "sidebarCollapse": {
      "property": "width",
      "duration": "200ms",
      "easing": "ease-in-out"
    },
    "dropdown": {
      "type": "fade-in + slide-down",
      "offset": "4px",
      "duration": "150ms",
      "easing": "ease-out"
    },
    "hover": {
      "properties": ["color", "background", "shadow", "border-color"],
      "duration": "150ms",
      "easing": "ease"
    },
    "toast": {
      "enter": {
        "type": "slide-in-right",
        "duration": "200ms",
        "easing": "ease-out"
      },
      "exit": {
        "type": "fade-out + slide-right",
        "duration": "150ms",
        "easing": "ease-in"
      }
    },
    "spinner": {
      "type": "rotate",
      "degrees": 360,
      "duration": "800ms",
      "easing": "linear",
      "iteration": "infinite"
    },
    "skeleton": {
      "type": "pulse",
      "opacityRange": [0.5, 1],
      "duration": "1500ms",
      "easing": "ease-in-out",
      "iteration": "infinite"
    },
    "faqAccordion": {
      "property": "height",
      "duration": "200ms",
      "easing": "ease-in-out"
    },
    "chartBars": {
      "type": "scale-up",
      "scaleFrom": 0,
      "duration": "400ms",
      "easing": "ease-out",
      "stagger": "50ms"
    },
    "countUp": {
      "duration": "800ms",
      "easing": "ease-out"
    },
    "floatingBadge": {
      "type": "float",
      "offset": "8px",
      "duration": "3000ms",
      "easing": "ease-in-out",
      "iteration": "infinite"
    }
  },

