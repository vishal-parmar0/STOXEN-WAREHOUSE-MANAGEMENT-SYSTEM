  "dashboardPage": {
    "layout": "three-column",
    "columns": {
      "sidebar": { "width": "240px", "position": "fixed-left" },
      "main": { "width": "fluid", "padding": "24px" },
      "rightPanel": { "width": "280px", "position": "fixed-right" }
    },
    "statsCards": [
      {
        "id": "total-products",
        "icon": "Package",
        "label": "Total Products",
        "topBarColor": "#0d9488",
        "iconBg": "#f0fdfa",
        "iconColor": "#0d9488",
        "changeType": "positive"
      },
      {
        "id": "stock-value",
        "icon": "DollarSign",
        "label": "Stock Value",
        "topBarColor": "#3b82f6",
        "iconBg": "#eff6ff",
        "iconColor": "#3b82f6",
        "changeType": "positive"
      },
      {
        "id": "low-stock",
        "icon": "AlertTriangle",
        "label": "Low Stock Items",
        "topBarColor": "#f59e0b",
        "iconBg": "#fffbeb",
        "iconColor": "#f59e0b",
        "changeType": "warning"
      },
      {
        "id": "pending-orders",
        "icon": "ClipboardList",
        "label": "Pending Orders",
        "topBarColor": "#22c55e",
        "iconBg": "#f0fdf4",
        "iconColor": "#22c55e",
        "changeType": "positive"
      }
    ],
    "stockMovementChart": {
      "type": "BarChart",
      "library": "Recharts",
      "height": "280px",
      "periods": ["7d", "30d", "90d"],
      "defaultPeriod": "7d",
      "barColorDefault": "#ccfbf1",
      "barColorActive": "#0d9488",
      "gridColor": "#e5e7eb",
      "gridStyle": "dashed"
    },
    "rightPanelSections": [
      {
        "id": "stock-overview",
        "title": "Stock Overview",
        "subtitle": "Quick stats",
        "type": "mini-stat-grid",
        "columns": 2
      },
      {
        "id": "stock-distribution",
        "title": "Stock by Category",
        "type": "donut-chart",
        "innerRadius": 55,
        "outerRadius": 80,
        "segments": [
          { "label": "In Stock", "color": "#0d9488", "percentage": 64 },
          { "label": "Low Stock", "color": "#ccfbf1", "percentage": 16 },
          { "label": "Out of Stock", "color": "#d1d5db", "percentage": 20 }
        ]
      },
      {
        "id": "top-suppliers",
        "title": "Top Suppliers",
        "type": "list",
        "maxItems": 5,
        "avatarStyle": "square-initials"
      },
      {
        "id": "expiry-alerts",
        "title": "Expiring Soon",
        "type": "alert-list",
        "thresholds": {
          "critical": { "days": 7, "color": "#ef4444" },
          "warning": { "days": 30, "color": "#f59e0b" }
        }
      }
    ]
  },

  "pages": {
    "login": {
      "layout": "centered-card",
      "cardMaxWidth": "420px",
      "background": "#f3f4f6"
    },
    "inventory": {
      "topBar": { "title": "Inventory", "cta": "Add Product" },
      "filters": ["search", "category", "stockStatus"],
      "tableColumns": ["Name", "SKU", "Category", "Qty", "Price", "Status", "Actions"]
    },
    "productDetail": {
      "layout": "split",
      "leftPanel": "product-info",
      "rightPanel": "stock-actions",
      "bottomSection": "transaction-history"
    },
    "transactions": {
      "tabs": ["All", "Stock IN", "Stock OUT", "Adjustments"],
      "filters": ["dateRange", "productSearch"],
      "tableColumns": ["Date", "Product", "Type", "Qty", "Previous → New", "User", "Notes"],
      "immutable": true
    },
    "suppliers": {
      "topBar": { "title": "Suppliers", "cta": "Add Supplier" },
      "viewModes": ["table", "cards"],
      "tableColumns": ["Name", "Contact", "Phone", "City", "Products", "Actions"]
    },
    "orders": {
      "tabs": ["All", "Purchase", "Dispatch"],
      "statusFilters": ["Pending", "Approved", "Processing", "Completed", "Cancelled"],
      "tableColumns": ["Order #", "Type", "Supplier/Customer", "Date", "Status", "Value"]
    },
    "reports": {
      "types": ["Inventory", "Transactions", "Low Stock", "Suppliers", "Orders"],
      "exportFormats": ["PDF", "CSV"],
      "filters": ["dateRange", "category", "status"]
    },
    "alerts": {
      "tabs": ["All", "Low Stock", "Expiry", "Order Status"],
      "actions": ["markRead", "markAllRead", "delete"]
    },
    "users": {
      "access": "admin-only",
      "tableColumns": ["Name", "Email", "Role", "Status", "Last Login", "Actions"],
      "cta": "Add User"
    },
    "settings": {
      "access": "admin-only",
      "sections": ["Warehouse Info", "Alert Configuration"],
      "fields": {
        "warehouseInfo": ["name", "address", "phone", "email"],
        "alertConfig": ["lowStockDays", "expiryAlertDays"]
      }
    }
  },

  "states": {
    "loading": {
      "fullPage": {
        "type": "logo-spinner",
        "logo": "Stoxen",
        "spinnerColor": "#0d9488"
      },
      "component": {
        "type": "skeleton",
        "color": "#e5e7eb",
        "pulseAnimation": true
      },
      "table": {
        "skeletonRows": 5
      }
    },
    "empty": {
      "iconSize": "64px",
      "iconColor": "#e5e7eb",
      "headingStyle": "heading-md",
      "headingColor": "#374151",
      "descriptionStyle": "body-md",
      "descriptionColor": "#6b7280",
      "ctaButton": true
    },
    "error": {
      "borderColor": "#ef4444",
      "icon": "AlertTriangle",
      "iconColor": "#ef4444",
      "messageColor": "#ef4444",
      "retryButton": true
    }
  }
}
