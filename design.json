  "spacing": {
    "unit": "4px",
    "scale": {
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "5": "20px",
      "6": "24px",
      "8": "32px",
      "10": "40px",
      "12": "48px",
      "16": "64px",
      "20": "80px",
      "24": "96px"
    },
    "semantic": {
      "inputPaddingX": "12px",
      "inputPaddingY": "10px",
      "cardPadding": "24px",
      "cardPaddingSm": "16px",
      "sidebarPaddingX": "16px",
      "sidebarPaddingY": "24px",
      "sectionPaddingY": "96px",
      "sectionPaddingYMobile": "48px",
      "navbarHeight": "64px",
      "topbarHeight": "64px",
      "pageContentPadding": "24px",
      "formFieldGap": "24px",
      "cardGap": "24px",
      "tableRowPaddingX": "16px",
      "tableRowPaddingY": "12px"
    }
  },

  "borders": {
    "radius": {
      "sm": "4px",
      "md": "6px",
      "lg": "8px",
      "xl": "12px",
      "2xl": "16px",
      "full": "9999px"
    },
    "width": {
      "default": "1px",
      "focus": "2px",
      "activeNav": "3px",
      "statCardTop": "3px"
    },
    "styles": {
      "default": "1px solid #e5e7eb",
      "focus": "2px solid #0d9488",
      "error": "2px solid #ef4444",
      "sidebar": "1px solid #e5e7eb",
      "tableRow": "1px solid #f3f4f6",
      "sectionDivider": "1px solid #e5e7eb"
    }
  },

  "shadows": {
    "sm": "0 1px 2px rgba(0, 0, 0, 0.05)",
    "md": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)",
    "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)",
    "xl": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1)",
    "focus": "0 0 0 3px rgba(13, 148, 136, 0.1)",
    "focusDanger": "0 0 0 3px rgba(239, 68, 68, 0.1)"
  },

  "components": {
    "buttons": {
      "primary": {
        "background": "#0d9488",
        "backgroundHover": "#0f766e",
        "text": "#ffffff",
        "padding": "10px 20px",
        "borderRadius": "6px",
        "fontSize": "14px",
        "fontWeight": 500,
        "shadow": "0 1px 2px rgba(0, 0, 0, 0.05)",
        "transition": "all 150ms ease"
      },
      "secondary": {
        "background": "transparent",
        "backgroundHover": "#f0fdfa",
        "text": "#0d9488",
        "border": "1px solid #0d9488",
        "padding": "10px 20px",
        "borderRadius": "6px",
        "fontSize": "14px",
        "fontWeight": 500
      },
      "dark": {
        "background": "#111827",
        "backgroundHover": "#1f2937",
        "text": "#ffffff",
        "padding": "12px 24px",
        "borderRadius": "6px",
        "fontSize": "14px",
        "fontWeight": 500
      },
      "danger": {
        "background": "#ef4444",
        "backgroundHover": "#dc2626",
        "text": "#ffffff",
        "padding": "10px 20px",
        "borderRadius": "6px",
        "fontSize": "14px",
        "fontWeight": 500
      },
      "ghost": {
        "background": "transparent",
        "backgroundHover": "#f3f4f6",
        "text": "#374151",
        "padding": "10px 20px",
        "borderRadius": "6px",
        "fontSize": "14px",
        "fontWeight": 500
      },
      "icon": {
        "background": "transparent",
        "backgroundHover": "#f3f4f6",
        "size": "36px",
        "borderRadius": "6px",
        "iconSize": "18px"
      }
    },

    "inputs": {
      "default": {
        "background": "#ffffff",
        "border": "1px solid #e5e7eb",
        "borderFocus": "2px solid #0d9488",
        "borderError": "2px solid #ef4444",
        "text": "#111827",
        "placeholder": "#9ca3af",
        "padding": "10px 12px",
        "borderRadius": "6px",
        "fontSize": "14px",
        "height": "40px",
        "focusRing": "0 0 0 3px rgba(13, 148, 136, 0.1)"
      },
      "label": {
        "fontSize": "14px",
        "fontWeight": 500,
        "color": "#374151",
        "marginBottom": "6px"
      },
      "errorText": {
        "fontSize": "12px",
        "color": "#ef4444",
        "marginTop": "4px"
      },
      "search": {
        "width": "240px",
        "borderRadius": "9999px",
        "background": "#f3f4f6",
        "border": "1px solid transparent",
        "borderFocus": "1px solid #0d9488"
      }
    },

    "cards": {
      "standard": {
        "background": "#ffffff",
        "border": "1px solid #e5e7eb",
        "borderRadius": "8px",
        "padding": "24px",
        "shadow": "none",
        "shadowHover": "0 1px 2px rgba(0, 0, 0, 0.05)"
      },
      "stat": {
        "background": "#ffffff",
        "border": "1px solid #e5e7eb",
        "borderRadius": "8px",
        "padding": "20px",
        "topBorderWidth": "3px",
        "topBorderColors": {
          "products": "#0d9488",
          "value": "#3b82f6",
          "lowStock": "#f59e0b",
          "orders": "#22c55e"
        }
      },
      "dark": {
        "background": "#111827",
        "border": "none",
        "borderRadius": "16px",
        "padding": "32px",
        "textColor": "#ffffff"
      },
      "miniStat": {
        "background": "#f9fafb",
        "borderRadius": "8px",
        "padding": "12px"
      }
    },

    "badges": {
      "stockIn": {
        "background": "#f0fdf4",
        "text": "#22c55e",
        "label": "↑ Stock IN"
      },
      "stockOut": {
        "background": "#fef2f2",
        "text": "#ef4444",
        "label": "↓ Stock OUT"
      },
      "adjustment": {
        "background": "#fffbeb",
        "text": "#f59e0b",
        "label": "~ Adjustment"
      },
      "pending": {
        "background": "#fffbeb",
        "text": "#f59e0b"
      },
      "approved": {
        "background": "#eff6ff",
        "text": "#3b82f6"
      },
      "processing": {
        "background": "#f0fdfa",
        "text": "#0d9488"
      },
      "completed": {
        "background": "#f0fdf4",
        "text": "#22c55e"
      },
      "cancelled": {
        "background": "#f3f4f6",
        "text": "#6b7280"
      },
      "lowStock": {
        "background": "#fffbeb",
        "text": "#f59e0b"
      },
      "outOfStock": {
        "background": "#fef2f2",
        "text": "#ef4444"
      },
      "roleAdmin": {
        "background": "#f0fdfa",
        "text": "#0d9488"
      },
      "roleManager": {
        "background": "#eff6ff",
        "text": "#3b82f6"
      },
      "roleStaff": {
        "background": "#f3f4f6",
        "text": "#374151"
      },
      "style": {
        "padding": "2px 8px",
        "borderRadius": "9999px",
        "fontSize": "12px",
        "fontWeight": 500,
        "display": "inline-flex",
        "alignItems": "center"
      }
    },

    "table": {
      "header": {
        "background": "#f9fafb",
        "fontSize": "12px",
        "fontWeight": 600,
        "color": "#6b7280",
        "textTransform": "uppercase",
        "padding": "12px 16px",
        "borderBottom": "1px solid #e5e7eb"
      },
      "row": {
        "background": "#ffffff",
        "backgroundHover": "#f9fafb",
        "fontSize": "14px",
        "color": "#374151",
        "padding": "12px 16px",
        "borderBottom": "1px solid #f3f4f6"
      }
    },

    "modal": {
      "overlay": {
        "background": "rgba(0, 0, 0, 0.5)",
        "backdropBlur": "2px"
      },
      "container": {
        "background": "#ffffff",
        "maxWidth": "520px",
        "borderRadius": "12px",
        "shadow": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1)"
      },
      "header": {
        "padding": "24px 24px 0"
      },
      "body": {
        "padding": "16px 24px"
      },
      "footer": {
        "padding": "0 24px 24px",
        "display": "flex",
        "justifyContent": "flex-end",
        "gap": "12px"
      }
    },

    "sidebar": {
      "width": "240px",
      "widthCollapsed": "64px",
      "mobileWidth": "256px",
      "mobileBreakpoint": "1024px",
      "background": "#ffffff",
      "borderRight": "1px solid #e5e7eb",
      "mobileDrawer": {
        "translateHidden": "-translate-x-full",
        "translateVisible": "translate-x-0",
        "transition": "transform 300ms ease",
        "backdrop": "bg-black/40 backdrop-blur-sm",
        "zIndex": 50,
        "closeButton": "X icon, top-right",
        "autoCloseOnNav": true
      },
      "navItem": {
        "padding": "10px 16px",
        "borderRadius": "6px",
        "fontSize": "14px",
        "margin": "2px 0",
        "default": {
          "color": "#6b7280",
          "iconColor": "#9ca3af"
        },
        "hover": {
          "background": "#f9fafb",
          "color": "#374151",
          "iconColor": "#374151"
        },
        "active": {
          "background": "#f0fdfa",
          "color": "#0d9488",
          "iconColor": "#0d9488",
          "fontWeight": 500,
          "leftBorder": "3px solid #0d9488"
        }
      },
      "badge": {
        "background": "#0d9488",
        "text": "#ffffff",
        "fontSize": "11px",
        "fontWeight": 600,
        "padding": "1px 6px",
        "borderRadius": "9999px",
        "minWidth": "20px"
      },
      "groupLabel": {
        "fontSize": "11px",
        "fontWeight": 500,
        "color": "#9ca3af",
        "textTransform": "uppercase",
        "letterSpacing": "0.5px",
        "padding": "8px 16px",
        "marginTop": "16px"
      }
    },

    "topbar": {
      "height": "64px",
      "background": "transparent",
      "padding": "0 12px (mobile) / 0 16px (sm) / 0 24px (lg)",
      "mobileHamburger": true,
      "searchHiddenBelow": "640px",
      "userNameHiddenBelow": "768px"
    },

    "rightPanel": {
      "width": "280px",
      "background": "#ffffff",
      "borderLeft": "1px solid #e5e7eb",
      "padding": "24px"
    },

    "avatar": {
      "sizes": {
        "sm": "32px",
        "md": "40px",
        "lg": "48px"
      },
      "borderRadius": "9999px",
      "background": "#0d9488",
      "text": "#ffffff",
      "fontWeight": 600,
      "border": "2px solid #ffffff",
      "supplier": {
        "borderRadius": "8px",
        "size": "36px"
      }
    }
  },

  "layout": {
    "landing": {
      "maxWidth": "7xl (80rem)",
      "navbarHeight": "~72px",
      "sectionPaddingY": "py-16 md:py-20 lg:py-24",
      "contentPaddingX": "px-6 md:px-12 lg:px-16",
      "theme": "dark (pure black #000 background)",
      "fontDisplay": "Syne",
      "fontBody": "Plus Jakarta Sans"
    },
    "dashboard": {
      "sidebarWidth": "240px",
      "sidebarWidthCollapsed": "64px",
      "sidebarMobileWidth": "256px",
      "mobileBreakpoint": "1024px",
      "mainContentPadding": "p-3 sm:p-4 lg:p-6",
      "cardGap": "24px",
      "statsColumns": "grid-cols-1 sm:grid-cols-2 lg:grid-cols-4",
      "pageBackground": "#f3f4f6"
    }
  },

  "breakpoints": {
    "xs": "0px",
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px",
    "responsiveRules": {
      "xl": "Full layout — sidebar + main content, right panel visible on dashboard",
      "lg": "Desktop sidebar (collapsible 240px/64px), main fluid",
      "md": "Mobile mode — sidebar becomes slide-out drawer (256px) with backdrop overlay",
      "sm": "Single column content, stacked cards, search hidden",
      "xs": "Full mobile — stacked everything, hamburger menu, user name hidden"
    }
  },

  "animations": {
    "pageTransition": {
      "type": "fade-in + slide-up",
      "offset": "8px",
      "duration": "200ms",
      "easing": "ease-out"
    },
    "modalOpen": {
      "type": "fade-in + scale",
      "scaleFrom": 0.95,
      "duration": "150ms",
      "easing": "ease-out"
    },
    "modalClose": {
      "type": "fade-out + scale",
      "scaleTo": 0.95,
      "duration": "100ms",
      "easing": "ease-in"
    },
    "sidebarCollapse": {
      "property": "width",
      "duration": "200ms",
      "easing": "ease-in-out"
    },
    "dropdown": {
      "type": "fade-in + slide-down",
      "offset": "4px",
      "duration": "150ms",
      "easing": "ease-out"
    },
    "hover": {
      "properties": ["color", "background", "shadow", "border-color"],
      "duration": "150ms",
      "easing": "ease"
    },
    "toast": {
      "enter": {
        "type": "slide-in-right",
        "duration": "200ms",
        "easing": "ease-out"
      },
      "exit": {
        "type": "fade-out + slide-right",
        "duration": "150ms",
        "easing": "ease-in"
      }
    },
    "spinner": {
      "type": "rotate",
      "degrees": 360,
      "duration": "800ms",
      "easing": "linear",
      "iteration": "infinite"
    },
    "skeleton": {
      "type": "pulse",
      "opacityRange": [0.5, 1],
      "duration": "1500ms",
      "easing": "ease-in-out",
      "iteration": "infinite"
    },
    "faqAccordion": {
      "property": "height",
      "duration": "200ms",
      "easing": "ease-in-out"
    },
    "chartBars": {
      "type": "scale-up",
      "scaleFrom": 0,
      "duration": "400ms",
      "easing": "ease-out",
      "stagger": "50ms"
    },
    "countUp": {
      "duration": "800ms",
      "easing": "ease-out"
    },
    "floatingBadge": {
      "type": "float",
      "offset": "8px",
      "duration": "3000ms",
      "easing": "ease-in-out",
      "iteration": "infinite"
    }
  },

